# Variables del listener (proceso separado del agente, ver listener/main.py).
# El .env real va en la raíz del proyecto (mismo nivel que este archivo).

# Proyecto GCP donde se creó el topic/subscription de Pub/Sub.
PUBSUB_PROJECT_ID=

# Nombre de la suscripción pull (no el topic).
PUBSUB_SUBSCRIPTION_ID=

# Ruta absoluta al JSON de la service account de la Chat app (opcional;
# sin esto el listener sigue funcionando pero no descarga adjuntos).
CHAT_SERVICE_ACCOUNT_FILE=

# Ver docs/chat_listener_setup.md para cómo obtener estos valores.
